# Container name — must match the hostname in the connector's mcp_url
CONTAINER_NAME=my-sidecar

# The stdio command that supergateway wraps
MCP_COMMAND=npx -y some-mcp-server serve

# Port supergateway listens on (default: 8000)
MCP_PORT=8000

# Local dev: publish port to host so broker (running outside Docker) can reach the sidecar.
# Leave empty for production (broker in Docker uses sidecar-internal network).
HOST_PORT=8000
