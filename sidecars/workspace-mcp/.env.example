# Local dev: publish port to host so broker (running outside Docker) can reach the sidecar.
# Leave empty for production (broker in Docker uses sidecar-internal network).
HOST_PORT=8010

# Google OAuth credentials — required for token validation in External OAuth Provider mode.
# The sidecar does NOT run OAuth flows; it uses these to verify incoming Bearer tokens.
# Must match the same credentials used by the broker.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
