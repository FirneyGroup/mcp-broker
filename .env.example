# Admin key (for /admin/* endpoints — key CRUD, token refresh)
BROKER_ADMIN_KEY=change-me-to-a-secure-random-string

# Token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
BROKER_ENCRYPTION_KEY=
BROKER_STATE_SECRET=change-me-to-a-secure-random-string

# Static connector credentials (discovery connectors don't need these)
# HubSpot (MCP Auth App)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Twitter/X (from X Developer Portal)
TWITTER_OAUTH2_CLIENT_ID=
TWITTER_OAUTH2_CLIENT_SECRET=

# Google OAuth (Web application, for workspace_mcp + bigquery connectors)
# Create at: https://console.cloud.google.com/apis/credentials
# Redirect URIs: http://localhost:8002/oauth/workspace_mcp/callback
#                http://localhost:8002/oauth/bigquery/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# LinkedIn (from LinkedIn Developer Portal)
# Create app at: https://developer.linkedin.com/
# Redirect URI: http://localhost:8002/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Slack (from api.slack.com/apps → Basic Information → App Credentials)
# Redirect URI: http://localhost:8002/oauth/slack/callback (or your public HTTPS URL)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Per-app broker keys are now managed via the admin API:
#   curl -X POST http://localhost:8002/admin/keys \
#     -H "X-Admin-Key: $BROKER_ADMIN_KEY" \
#     -H "Content-Type: application/json" \
#     -d '{"app_key": "my_company:app1"}'
# The returned br_* key becomes the X-Broker-Key header value in your MCP client's config.
