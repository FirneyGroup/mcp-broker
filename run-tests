#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# MCP Broker Test Runner
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TESTS_DIR="$SCRIPT_DIR/tests"

# PYTHONPATH — src/ contains broker and connectors packages
export PYTHONPATH="${SCRIPT_DIR}/src:${PYTHONPATH:-}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# -----------------------------------------------------------------------------
# Usage
# -----------------------------------------------------------------------------

usage() {
    echo "Usage: $0 [options] [pytest-args]"
    echo ""
    echo "Options:"
    echo "  --verbose, -v     Verbose output"
    echo "  --help, -h        Show this help"
    echo ""
    echo "Examples:"
    echo "  $0                        # Run all tests"
    echo "  $0 -v                     # Verbose output"
    echo "  $0 -k 'test_discovery'    # Run tests matching pattern"
}

# -----------------------------------------------------------------------------
# Parse Arguments
# -----------------------------------------------------------------------------

VERBOSE=""
PYTEST_ARGS=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -v|--verbose)
            VERBOSE="-v"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            PYTEST_ARGS="$PYTEST_ARGS $1"
            shift
            ;;
    esac
done

# -----------------------------------------------------------------------------
# Run Tests
# -----------------------------------------------------------------------------

echo -e "${YELLOW}Running MCP Broker tests${NC}"
echo ""

cd "$SCRIPT_DIR"

# Ensure test dependencies
if ! python -c "import pytest" 2>/dev/null; then
    echo -e "${RED}pytest not found. Install with: pip install -e '.[dev]'${NC}"
    exit 1
fi

if ! python -c "import respx" 2>/dev/null; then
    echo -e "${RED}respx not found. Install with: pip install -e '.[dev]'${NC}"
    exit 1
fi

# Run pytest (asyncio_mode configured in pyproject.toml)
if pytest $VERBOSE "$TESTS_DIR" $PYTEST_ARGS; then
    echo ""
    echo -e "${GREEN}All tests passed!${NC}"
else
    echo ""
    echo -e "${RED}Some tests failed.${NC}"
    exit 1
fi
